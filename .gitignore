# ─── IDEs y editores ───────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Docker ────────────────────────────────────────────────
docker-compose.override.yml

# ─── Secretos — NUNCA en el repositorio ───────────────────
*.env
.env.*
!.env.example
!backend/.env.example
!frontend/.env.example
secrets/
*.pem
*.key
*.p12

# ─── Logs ──────────────────────────────────────────────────
*.log
logs/
*.pid

# ─── Alembic ───────────────────────────────────────────────
# (no ignorar las migraciones, solo los temporales)
backend/alembic/versions/*.pyc

# ─── Media de la finca (no versionar binarios pesados) ─────
# Las fotos/videos van a Supabase Storage, no al repo
*.MP4
*.MOV
*.mov
# Excepciones: fotos pequeñas de UI que sí deben estar en el repo
!frontend/public/icons/*.png
!frontend/public/og-image.jpg
# Imágenes sueltas en raíz
*.JPG
*.jpg
