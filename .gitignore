# ─── Node.js / Frontend ────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
frontend/.nuxt/
frontend/.output/
frontend/dist/
frontend/.cache/
