# App
APP_NAME=Hacienda La Carmelita API
ENVIRONMENT=development
DEBUG=true

# Database (Supabase)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hacienda_carmelita
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/hacienda_carmelita

# Redis (Upstash)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Twilio (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=reservas@haciendalacarmelita.com

# Wompi (Colombia) — usar sandbox=true hasta producción
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxx
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_KEY=test_integrity_xxxx
WOMPI_SANDBOX=true

# Stripe (Internacional)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_SANDBOX=true

# URL base del frontend (para redirect URLs de pasarelas de pago)
FRONTEND_URL=http://localhost:3000

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Channel Manager — Lodgify
# Obtener en: https://app.lodgify.com/settings/api
LODGIFY_API_KEY=
LODGIFY_BASE_URL=https://api.lodgify.com/v2
LODGIFY_PROPERTY_ID=

# Admin
ADMIN_EMAIL=admin@haciendalacarmelita.com
ADMIN_WHATSAPP=+573000000000
